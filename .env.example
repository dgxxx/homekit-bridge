# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# MQTT broker (the ccu3 + solaredge services publish here)
MQTT_HOST=127.0.0.1
MQTT_PORT=1883

# Optional password for the web UI (HTTP Basic Auth, any username).
# Leave blank to disable authentication.
WEB_PASSWORD=

# Directory where HAP pairing state and the SQLite DB are stored.
# Must be a persistent volume mount when running in Docker.
STATE_DIR=/app/state

# Web UI bind address and port (default: all interfaces, port 8095)
# WEB_HOST=0.0.0.0
# WEB_PORT=8095
