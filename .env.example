# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# MQTT broker (the ccu3 + solaredge services publish here)
MQTT_HOST=127.0.0.1
MQTT_PORT=1883

# Optional password for the web UI (HTTP Basic Auth, any username).
# Leave blank to disable authentication.
WEB_PASSWORD=

# Directory where HAP pairing state and the SQLite DB are stored.
# Must be a persistent volume mount when running in Docker.
STATE_DIR=/app/state

# Fixed HomeKit pairing identity (optional). pyhap does NOT persist the setup
# code, so without HOMEKIT_PIN it is regenerated on every restart. Setting both
# keeps the setup code AND the bridge identity stable across restarts — and
# recreates the same identity even if state/hap.state is lost (no re-pairing).
# Leave blank to let pyhap generate random values on first start.
# PIN format: ddd-dd-ddd (avoid trivial codes like 123-45-678 / 111-11-111).
HOMEKIT_PIN=
HOMEKIT_MAC=

# Web UI bind address and port (default: all interfaces, port 8095)
# WEB_HOST=0.0.0.0
# WEB_PORT=8095

# Expose SolarEdge PV data as HomeKit accessories. Off by default: HomeKit has
# no native watt/kWh characteristic, so the stock Home app shows these tiles in
# a confusing way (watts as "lux", an energy "switch", etc.). Set to true to
# build them anyway. Accepted truthy values: 1, true, yes, on.
PV_ENABLED=false

# Automatic daily configuration backup into STATE_DIR/backups. On by default;
# set BACKUP_ENABLED=false (or 0/no/off) to disable. BACKUP_RETENTION controls
# how many daily snapshots to keep (older ones are pruned). Manual backup /
# restore is always available in the web UI under "Sicherung".
# BACKUP_ENABLED=true
# BACKUP_RETENTION=14
