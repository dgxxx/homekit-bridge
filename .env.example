# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# IP address or hostname of the Homematic CCU3
CCU3_HOST=

# IP address or hostname of the SolarEdge inverter (Modbus TCP on port 1502)
SOLAREDGE_HOST=

# Modbus unit ID of the SolarEdge inverter (default: 1)
SOLAREDGE_UNIT_ID=1

# Optional password for the web UI (HTTP Basic Auth, any username).
# Leave blank to disable authentication.
WEB_PASSWORD=

# Directory where HAP pairing state and the SQLite DB are stored.
# Must be a persistent volume mount when running in Docker.
STATE_DIR=/app/state

# Web UI bind address and port (default: all interfaces, port 8095)
# WEB_HOST=0.0.0.0
# WEB_PORT=8095
